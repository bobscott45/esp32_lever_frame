menu "WiFi Configuration"

    config WIFI_DEFAULT_SSID
        string "Default WiFi SSID (for development)"
        default ""
        help
            If the device's NVS memory is wiped, it will attempt to connect to this SSID automatically,
            bypassing the need to provision it via the WebUI on every re-flash. 
            WARNING: Will be saved in plaintext in sdkconfig!

    config WIFI_DEFAULT_PASSWORD
        string "Default WiFi Password"
        default ""
        help
            The password for the default WiFi SSID.

endmenu

menu "OpenLCB Node Configuration"

    config OPENLCB_NODE_ID
        hex "OpenLCB Node ID (48-bit)"
        default 0x05010101A604
        help
            The 48-bit (6 byte) globally unique Node ID for this device.
            This value must be unique for every physical node on your layout.

endmenu

menu "Hardware Workarounds"

    config HARDWARE_IGNORE_BROWNOUT_ON_WAKE
        bool "Disable Brownout Detector during Backlight Wake"
        default n
        help
            Temporarily disables the ESP32 Brownout Detector for 50ms when the 
            display backlight turns on. This prevents the board from rebooting 
            if the backlight inrush current momentarily drops the voltage.
            Enable this if your board reboots when waking from sleep.

endmenu
